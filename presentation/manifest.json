{
  "id": "presentation",
  "name": "Presentation",
  "version": "0.0.1",
  "host_api_version": "1",
  "backend": {
    "transport": "stdio",
    "entrypoint": "./presentation-plugin",
    "args": []
  },
  "tools": [],
  "ui": {
    "panels": [
      {
        "name": "slide_editor_panel",
        "kind": "godot_scene",
        "entry_scene": "ui/SlideEditorPanel.tscn",
        "scripts": [
          "ui/SlideEditorPanel.gd",
          "ui/slide_model.gd",
          "ui/slide_list_panel.gd",
          "ui/slide_canvas.gd",
          "ui/tile_inspector.gd",
          "ui/presentation_tile_kind_base.gd",
          "ui/presentation_tile_kind_text.gd",
          "ui/presentation_tile_kind_image.gd",
          "ui/presentation_tile_kind_spreadsheet.gd",
          "ui/presentation_tile_annotation_host.gd"
        ],
        "file_extensions": [".mdeck"],
        "ipc_channels": [],
        "save_mode": "host_owned"
      }
    ],
    "ipc_messages": []
  },
  "editor_items": [
    {
      "id": "new_mdeck",
      "name": "New Slide Deck",
      "panel": "slide_editor_panel",
      "default_filename": "untitled.mdeck"
    }
  ],
  "capabilities": ["host_owned_save"],
  "permissions": {
    "host_capabilities": [
      "host.documents.list_open",
      "host.documents.get_state",
      "host.documents.set_state",
      "host.documents.get_node",
      "host.documents.get_blob",
      "host.documents.patch_state",
      "host.documents.put_blob"
    ],
    "network": {
      "mode": "none"
    },
    "filesystem": {
      "mode": "none",
      "paths": []
    }
  },
  "data_directory": "",
  "autostart": false,
  "auto_reload": true
}
