# Built Go binaries — build from source per FCIB policy.
# Match every plugin's binary regardless of name pattern.
*/cad-plugin
*/cad-plugin.exe
*/cad-plugin-*
# Generic catch for plugin binaries built at the plugin root.
# Add new patterns here as additional plugins land.

# Runtime build artifacts (PBS Python tarballs etc.)
*/runtime-build/*.tar.zst
*/runtime-build/*.tar.gz
*/runtime-build/*.zip

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.venv/
venv/
env/

# IDE / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Godot import cache (not authoritative; regenerated on open)
.godot/
